{
  // REST Blueprint — base settings (applied to all environments).
  // Override values in appsettings.{Environment}.json as needed.
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    // Leave empty to use the in-memory output cache fallback.
    // Set to a valid Redis connection string (e.g. "localhost:6379") to enable Redis output caching.
    // TEMPLATE NOTE: In production wire this from environment variables or a secrets manager.
    "redis": ""
  },
  "Cors": {
    // Production-mode allowed origins. In Development all origins are permitted.
    // TEMPLATE NOTE: Replace with your actual front-end origin(s) before deploying.
    "AllowedOrigins": [ "https://your-frontend.example.com" ]
  },
  "Authentication": {
    // Symmetric JWT configuration.
    // TEMPLATE NOTE: Override SecretKey in appsettings.Development.json or user secrets.
    //                In production load from environment variable / secrets manager (never commit a real key).
    "Issuer": "RestBlueprint",
    "Audience": "rest-blueprint-clients",
    "SecretKey": "placeholder-secret-key-change-in-production-32chars!"
  }
}
