{
  // REST Blueprint — Development overrides.
  // These values are used ONLY when ASPNETCORE_ENVIRONMENT=Development.
  //
  // ⚠️  SECURITY NOTE: This file is committed to source control for developer convenience ONLY.
  //     The symmetric key here is for local exploration. Replace it with a strong random key
  //     (≥32 bytes) and NEVER reuse this key in staging or production environments.
  //
  // To generate a strong key: openssl rand -base64 32
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "ConnectionStrings": {
    // Uncomment and set to enable Redis caching in development.
    // "redis": "localhost:6379"
    "redis": ""
  },
  "Authentication": {
    "Issuer": "RestBlueprint",
    "Audience": "rest-blueprint-clients",
    // DEV ONLY — change this to any 32+ character string you like.
    "SecretKey": "dev-only-secret-key-change-in-production-32chars!"
  }
}
